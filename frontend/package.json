{
  "name": "@modulr/frontend",
  "version": "1.0.0",
  "description": "Modulr cross-platform frontend ecosystem",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:telegram": "vite build --config vite.config.telegram.ts",
    "build:web": "vite build --config vite.config.web.ts",
    "build:mobile": "vite build --config vite.config.mobile.ts",
    "build:desktop": "tauri build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.72.6",
    "react-native-web": "^0.19.9",
    "@tanstack/react-query": "^5.8.4",
    "zustand": "^4.4.6",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.294.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "date-fns": "^2.30.0",
    "recharts": "^2.8.0",
    "react-hook-form": "^7.48.2",
    "@hookform/resolvers": "^3.3.2",
    "zod": "^3.22.4",
    "dexie": "^3.2.4",
    "dexie-react-hooks": "^1.1.7",
    "capacitor-secure-storage": "^0.6.3",
    "@capacitor/geolocation": "^5.0.6",
    "@capacitor/camera": "^5.0.7",
    "@capacitor/haptics": "^5.0.6",
    "@capacitor/push-notifications": "^5.0.6",
    "@capacitor/network": "^5.0.6",
    "@capacitor/app": "^5.0.6",
    "@capacitor/splash-screen": "^5.0.6",
    "@capacitor/status-bar": "^5.0.6",
    "@twa-dev/sdk": "^2.2.0",
    "@tauri-apps/api": "^1.5.1",
    "react-router-dom": "^6.18.0",
    "react-router-native": "^6.18.0",
    "framer-motion": "^10.16.4",
    "react-intersection-observer": "^9.5.3",
    "react-hotkeys-hook": "^4.4.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-window": "^1.8.8",
    "react-window-infinite-loader": "^1.0.9",
    "react-virtualized-auto-sizer": "^1.0.20",
    "i18next": "^23.6.0",
    "react-i18next": "^13.5.0",
    "i18next-browser-languagedetector": "^7.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/react-window": "^1.8.6",
    "@types/react-beautiful-dnd": "^13.1.6",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.4",
    "vite-plugin-windicss": "^1.9.3",
    "typescript": "^5.2.2",
    "tailwindcss": "^3.3.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "windicss": "^3.5.6",
    "eslint": "^8.54.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.1",
    "@testing-library/react": "^13.4.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/user-event": "^14.5.1",
    "@storybook/react": "^7.5.3",
    "@storybook/react-vite": "^7.5.3",
    "@storybook/addon-essentials": "^7.5.3",
    "storybook": "^7.5.3",
    "msw": "^2.0.7",
    "playwright": "^1.40.1",
    "@playwright/test": "^1.40.1",
    "@tauri-apps/cli": "^1.5.8",
    "@capacitor/cli": "^5.6.0",
    "react-native-cli": "^2.0.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
