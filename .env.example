# .env.example
TELEGRAM_TOKEN=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telegram_bot
DB_USER=postgres
DB_PASS=
DB_SSLMODE=disable
# Для production/staging RLS-совместимый путь:
# 1. go run ./databases/cmd/databases app-role-sql -role=modulr_app
# 2. Выполни SQL под DBA / owner role
# 3. Переключи DB_USER/DB_PASS на modulr_app и проверь go run ./databases/cmd/databases rls-status
AI_PROVIDER=openai
LOG_LEVEL=info
